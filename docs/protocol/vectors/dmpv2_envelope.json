[
  {
    "description": "round-trip: short ASCII body, alice@example.com",
    "expected_decode_body_hex": "68656c6c6f20626f62",
    "expected_decode_from": "alice@example.com",
    "expected_plaintext_hex": "444d5056323a7b2266726f6d223a22616c696365406578616d706c652e636f6d227d0a68656c6c6f20626f62",
    "inputs": {
      "body_hex": "68656c6c6f20626f62",
      "sender_addr": "alice@example.com"
    }
  },
  {
    "description": "edge case: empty body",
    "expected_decode_body_hex": "",
    "expected_decode_from": "alice@example.com",
    "expected_plaintext_hex": "444d5056323a7b2266726f6d223a22616c696365406578616d706c652e636f6d227d0a",
    "inputs": {
      "body_hex": "",
      "sender_addr": "alice@example.com"
    }
  },
  {
    "description": "edge case: binary body covering 0..255",
    "expected_decode_body_hex": "",
    "expected_decode_from": "alice@example.com",
    "expected_plaintext_hex": "",
    "inputs": {
      "body_hex": "",
      "sender_addr": "alice@example.com"
    }
  },
  {
    "description": "canonicalization: mixed-case input normalizes",
    "expected_decode_body_hex": "6869",
    "expected_decode_from": "alice@example.com",
    "expected_plaintext_hex": "444d5056323a7b2266726f6d223a22616c696365406578616d706c652e636f6d227d0a6869",
    "inputs": {
      "body_hex": "6869",
      "sender_addr": "ALICE@Example.COM."
    }
  },
  {
    "description": "v1: sender_addr=None emits raw body, no wrapper",
    "expected_decode_body_hex": "756e77726170706564206c6567616379",
    "expected_decode_from": null,
    "expected_plaintext_hex": "756e77726170706564206c6567616379",
    "inputs": {
      "body_hex": "756e77726170706564206c6567616379",
      "sender_addr": null
    }
  },
  {
    "description": "reject path: non-canonical sender_addr falls back to v1",
    "expected_decode_body_hex": "706c61696e",
    "expected_decode_from": null,
    "expected_plaintext_hex": "706c61696e",
    "inputs": {
      "body_hex": "706c61696e",
      "sender_addr": "not-an-address"
    }
  },
  {
    "description": "forward-compat: extra header keys are ignored, from still parses",
    "expected_decode_body_hex": "666f72776172642d636f6d70617420626f6479",
    "expected_decode_from": "alice@example.com",
    "inputs": {
      "plaintext_hex": "444d5056323a7b2266726f6d223a22616c696365406578616d706c652e636f6d222c227265706c795f746f223a22626f62406578616d706c652e636f6d227d0a666f72776172642d636f6d70617420626f6479"
    }
  },
  {
    "description": "v1 collision: prefix + non-JSON header falls back to the full plaintext, body untouched",
    "expected_decode_body_hex": "444d5056323a7b6e6f74206a736f6e7d0a626f64792d7374696c6c2d68657265",
    "expected_decode_from": null,
    "inputs": {
      "plaintext_hex": "444d5056323a7b6e6f74206a736f6e7d0a626f64792d7374696c6c2d68657265"
    }
  }
]
