# Per-node env file for docker-compose.cluster.yml service `node-a`.
# See docs/deployment/cluster.md for the operator guide.
#
# DMP_SYNC_PEERS lists the OTHER two nodes. Each entry is an HTTP base
# URL (no /v1/sync/* suffix; the worker appends it). Container DNS
# names come from the `container_name:` keys in the compose file and
# are only resolvable inside the dnsmesh-cluster docker network.
DMP_SYNC_PEERS=http://dnsmesh-node-b:8053,http://dnsmesh-node-c:8053

# Shared operator token. Every node in the cluster uses the SAME value
# so any peer can authenticate to any other. Change this to a strong
# random string before running in production; the sample value is a
# dev-only placeholder.
DMP_SYNC_PEER_TOKEN=dev-cluster-token-change-me

# Anti-entropy sync cadence. 2s keeps the test fast; production can
# run 30..300s comfortably since the only cost is a digest fetch that
# returns nothing when the cluster is already converged.
DMP_SYNC_INTERVAL_SECONDS=2

# Optional: pin the operator Ed25519 signing public key here so the
# node re-verifies cluster-manifest records pulled from peers. The
# value is the hex-encoded 32-byte public key; the generate script
# prints it on first run. Uncomment after generating the manifest:
# DMP_SYNC_OPERATOR_SPK=__operator_public_key_hex__

# Mounted read-only at /etc/dmp/cluster-manifest.wire by the compose
# file. The worker currently prefers DMP_SYNC_PEERS over the manifest
# for peer discovery; the manifest is kept around so clients fetching
# the cluster record over DNS can still verify node listings.
DMP_CLUSTER_MANIFEST_PATH=/etc/dmp/cluster-manifest.wire

# Human-readable node id used in anti-entropy logs.
DMP_NODE_ID=node-a

# Structured logs for easy log aggregation.
DMP_LOG_FORMAT=json
DMP_LOG_LEVEL=INFO
